-- 5. RLS sur tarifs_baremes
-- Lecture publique (app), écriture admin uniquement
-- ─────────────────────────────────────────────────────────────────

ALTER TABLE public.tarifs_baremes ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "Lecture publique tarifs" ON public.tarifs_baremes;
CREATE POLICY "Lecture publique tarifs" ON public.tarifs_baremes
  FOR SELECT USING (TRUE);

DROP POLICY IF EXISTS "Admin modifie tarifs" ON public.tarifs_baremes;
CREATE POLICY "Admin modifie tarifs" ON public.tarifs_baremes
  FOR ALL USING (
    EXISTS (
      SELECT 1 FROM utilisateurs
      WHERE id = auth.uid() AND role = 'admin'
    )
  );

-- RLS sur config_tarifs (même logique)
ALTER TABLE public.config_tarifs ENABLE ROW LEVEL SECURITY;

DROP POLICY IF EXISTS "Lecture publique config_tarifs" ON public.config_tarifs;
CREATE POLICY "Lecture publique config_tarifs" ON public.config_tarifs
  FOR SELECT USING (TRUE);

DROP POLICY IF EXISTS "Admin modifie config_tarifs" ON public.config_tarifs;
CREATE POLICY "Admin modifie config_tarifs" ON public.config_tarifs
  FOR ALL USING (
    EXISTS (
      SELECT 1 FROM utilisateurs
      WHERE id = auth.uid() AND role = 'admin'
    )
  );

