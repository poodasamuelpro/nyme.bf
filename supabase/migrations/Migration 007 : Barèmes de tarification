-- ─────────────────────────────────────────────────────────────────
-- 4. FONCTION SQL : calculer_prix_livraison
-- Utilisée côté serveur (route.ts) pour calcul officiel
-- ─────────────────────────────────────────────────────────────────

CREATE OR REPLACE FUNCTION public.calculer_prix_livraison(
  p_distance_km NUMERIC,
  p_type        TEXT DEFAULT 'immediate',
  p_pluie       BOOLEAN DEFAULT FALSE
) RETURNS NUMERIC
LANGUAGE plpgsql STABLE SECURITY DEFINER AS $$
DECLARE
  v_config       config_tarifs%ROWTYPE;
  v_prix         NUMERIC := 0;
  v_frais_fixe   NUMERIC;
  v_baremes      RECORD;
  v_km_restant   NUMERIC;
  v_km_tranche   NUMERIC;
BEGIN
  -- Charger la config active
  SELECT * INTO v_config FROM config_tarifs WHERE actif = TRUE ORDER BY updated_at DESC LIMIT 1;
  IF NOT FOUND THEN
    RAISE EXCEPTION 'Aucune configuration tarifaire active';
  END IF;

  -- Choisir les frais fixes selon le type
  IF p_type = 'urgente' THEN
    v_frais_fixe := v_config.frais_fixe_urgente;
  ELSIF p_type = 'programmee' THEN
    v_frais_fixe := v_config.frais_fixe_programmee;
  ELSE
    v_frais_fixe := v_config.frais_fixe_immediate;
  END IF;

  v_prix := v_frais_fixe;
  v_km_restant := p_distance_km;

  -- Appliquer les barèmes par tranche dans l'ordre
  FOR v_baremes IN
    SELECT km_min, km_max, prix_par_km
    FROM tarifs_baremes
    WHERE actif = TRUE
    ORDER BY ordre ASC
  LOOP
    EXIT WHEN v_km_restant <= 0;

    v_km_tranche := LEAST(v_km_restant, v_baremes.km_max - v_baremes.km_min);
    v_prix := v_prix + (v_km_tranche * v_baremes.prix_par_km);
    v_km_restant := v_km_restant - v_km_tranche;
  END LOOP;

  -- Si distance dépasse le dernier barème, utiliser le tarif du dernier
  IF v_km_restant > 0 THEN
    SELECT prix_par_km INTO v_km_tranche
    FROM tarifs_baremes WHERE actif = TRUE ORDER BY ordre DESC LIMIT 1;
    v_prix := v_prix + (v_km_restant * COALESCE(v_km_tranche, 400));
  END IF;

  -- Modificateurs de type
  IF p_type = 'urgente' THEN
    v_prix := v_prix * v_config.multiplicateur_urgente;
  ELSIF p_type = 'programmee' THEN
    v_prix := v_prix * v_config.multiplicateur_programmee;
  END IF;

  -- Modificateur météo
  IF p_pluie AND v_config.pluie_actif THEN
    v_prix := v_prix * v_config.multiplicateur_pluie;
  END IF;

  -- Appliquer le minimum
  v_prix := GREATEST(v_prix, v_config.prix_minimum);

  RETURN ROUND(v_prix);
END;
$$;

