-- ─────────────────────────────────────────────────────────────────
-- 1. CRÉER LA TABLE tarifs_baremes (remplace le tarif_km unique)
-- ─────────────────────────────────────────────────────────────────

CREATE TABLE IF NOT EXISTS public.tarifs_baremes (
  id              UUID    PRIMARY KEY DEFAULT uuid_generate_v4(),
  -- Tranche kilométrique
  km_min          NUMERIC(6,2) NOT NULL,  -- borne inférieure (incluse)
  km_max          NUMERIC(6,2) NOT NULL,  -- borne supérieure (exclue, sauf dernière)
  prix_par_km     NUMERIC(8,2) NOT NULL,  -- XOF par km dans cette tranche
  label           TEXT    NOT NULL,       -- ex: "0 à 3.5 km"
  -- Ordre d'application
  ordre           INTEGER NOT NULL,
  -- Activation
  actif           BOOLEAN NOT NULL DEFAULT TRUE,
  -- Audit
  created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),

  CONSTRAINT tarifs_baremes_km_check CHECK (km_min >= 0 AND km_max > km_min),
  CONSTRAINT tarifs_baremes_prix_check CHECK (prix_par_km > 0)
);

-- Index pour lecture ordonnée rapide
CREATE INDEX IF NOT EXISTS idx_tarifs_baremes_ordre
  ON public.tarifs_baremes (ordre)
  WHERE actif = TRUE;

-- Trigger updated_at
CREATE OR REPLACE FUNCTION public.update_tarifs_baremes_updated_at()
RETURNS TRIGGER LANGUAGE plpgsql AS $$
BEGIN NEW.updated_at = NOW(); RETURN NEW; END;
$$;

DROP TRIGGER IF EXISTS trg_tarifs_baremes_updated_at ON public.tarifs_baremes;
CREATE TRIGGER trg_tarifs_baremes_updated_at
  BEFORE UPDATE ON public.tarifs_baremes
  FOR EACH ROW EXECUTE FUNCTION public.update_tarifs_baremes_updated_at();

